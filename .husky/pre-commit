#!/bin/sh

echo "=== Running pre-commit hooks ==="

# 1. Lint Python files (Backend)
if command -v flake8 >/dev/null 2>&1; then
  echo "Linting backend Python files..."
  flake8 . --count --statistics --max-line-length=140 --ignore=E127,E225,E226,E231,E302,E305,E401,E402,E701,E702,F401,F541,F841,W503,W504 --exclude=venv,node_modules,frontend,migrations,__pycache__,*.pyc
  if [ $? -ne 0 ]; then
    echo "❌ Flake8 linting failed. Please fix Python issues before committing."
    exit 1
  fi
else
  # On Windows, try calling python's flake8 if flake8 command isn't directly in path
  if [ -f "venv/Scripts/flake8" ]; then
    echo "Linting backend Python files (using venv)..."
    venv/Scripts/flake8 . --count --statistics --max-line-length=140 --ignore=E127,E225,E226,E231,E302,E305,E401,E402,E701,E702,F401,F541,F841,W503,W504 --exclude=venv,node_modules,frontend,migrations,__pycache__,*.pyc
    if [ $? -ne 0 ]; then
      echo "❌ Flake8 linting failed. Please fix Python issues before committing."
      exit 1
    fi
  else
    echo "⚠️ Flake8 not installed in path or venv, skipping Python linting."
  fi
fi

# 2. Lint TS/JS/React files (Frontend)
echo "Linting frontend files..."
cd frontend
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ ESLint failed. Please fix TypeScript/React issues before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
